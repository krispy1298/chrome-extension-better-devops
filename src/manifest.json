{
  "name": "Better Azure Boards",
  "version": "1.1.0.2",
  "manifest_version": 3,
  "description": "A Chrome Extension to have a better experience in Azure Boards",
  "content_scripts": [
    {
      "matches": ["https://*.visualstudio.com/*"],
      "css": ["inject.css"],
      "js": ["inject.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "options.html",
  "permissions": ["storage"]
}
